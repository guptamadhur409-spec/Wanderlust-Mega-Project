def buildRequired = false

pipeline {

    agent {
        label 'ubuntu'
    }

    options {
        timestamps()
        ansiColor('xterm')
        disableConcurrentBuilds()
        skipDefaultCheckout(true)

        buildDiscarder(logRotator(
            numToKeepStr: '20',
            artifactNumToKeepStr: '10'
        ))
    }

    environment {
        APP_NAME = "wanderlust-frontend"
        ACR_REGISTRY = "akstestingregistrymgre.azurecr.io"
        SONAR_HOME = tool 'Sonar'
    }

    stages {

        stage('Checkout') {
            steps {

                echo "Checking out source code..."

                checkout scm

                sh '''
                    echo "Current Workspace"
                    pwd

                    echo "Repository Contents"
                    ls -la

                    echo "Frontend Directory"
                    ls -la frontend
                '''
            }
        }

        stage('Verify Build Agent') {
            steps {

                sh '''
                    echo "========= Installed Tools ========="

                    git --version
                    node --version
                    npm --version
                    docker --version
                    kubectl version --client
                    helm version
                    az version
                    java -version
                    trivy --version
                    sonar-scanner --version
                    trufflehog --version || echo "TruffleHog not found"
                '''
            }
        }

        stage('Secret Scan') {

            steps {

                sh '''
                    echo "Scanning git history for secrets with TruffleHog..."
                    echo "TruffleHog version:"
                    trufflehog --version

                    trufflehog git file://. --no-update --json > trufflehog-results.json 2>&1 || true

                    echo "Scan output:"
                    cat trufflehog-results.json

                    SECRETS_FOUND=$(grep -c "DetectorName" trufflehog-results.json 2>/dev/null || echo "0")

                    if [ "$SECRETS_FOUND" -gt "0" ]; then
                        echo "========== SECRETS DETECTED =========="
                        echo "Found $SECRETS_FOUND secret(s) in git history!"
                        echo "======================================="
                        exit 1
                    else
                        echo "No secrets found in git history."
                    fi
                '''

            }

        }

        stage('Detect Frontend Changes') {

            steps {

                script {

                    /*
                     * Compare previous successful build with current commit.
                     * First build fallback -> HEAD~1
                     */

                    def previousCommit = env.GIT_PREVIOUS_SUCCESSFUL_COMMIT

                    def currentCommit = env.GIT_COMMIT

                    def diffCommand

                    if (previousCommit?.trim()) {
                        diffCommand = "git diff --name-only ${previousCommit} ${currentCommit}"
                    } else {
                        diffCommand = "git diff --name-only HEAD~1 HEAD || true"
                    }

                    def changedFiles = sh(
                        script: diffCommand,
                        returnStdout: true
                    ).trim().split('\n')

                    echo "========== Changed Files =========="

                    changedFiles.each {
                        echo it
                    }

                    def triggerPatterns = [

                        ~/^frontend\/src\/.*/,
                        ~/^frontend\/public\/.*/,
                        ~/^frontend\/package\.json$/,
                        ~/^frontend\/package-lock\.json$/,
                        ~/^frontend\/vite\.config\.ts$/,
                        ~/^frontend\/tsconfig.*$/,
                        ~/^frontend\/tailwind\.config\.js$/,
                        ~/^frontend\/postcss\.config\.js$/,
                        ~/^frontend\/components\.json$/,
                        ~/^frontend\/index\.html$/,
                        ~/^frontend\/Dockerfile$/,
                        ~/^frontend\/\.env.*/
                    ]

                    for (file in changedFiles) {

                        if (triggerPatterns.any { file ==~ it }) {

                            buildRequired = true
                            break

                        }

                    }

                    if (!buildRequired) {

                        echo "No frontend application changes detected. Skipping pipeline."
                        currentBuild.result = 'NOT_BUILT'
                        currentBuild.description = 'Skipped - no frontend code changes'

                    } else {

                        echo "Frontend changes detected."

                    }

                }

            }

        }

        stage('Install Dependencies') {

            when {
                expression { buildRequired }
            }

            steps {

                dir('frontend') {

                    sh '''
                        echo "Installing Node Packages..."
                        npm ci
                    '''

                }

            }

        }

        stage('Dependency Scan') {

            when {
                expression { buildRequired }
            }

            steps {

                dir('frontend') {

                    sh '''
                        echo "Scanning dependencies for vulnerabilities..."

                        # 1) Trivy report for visibility and triage (do not fail here)
                        trivy fs \
                          --scanners vuln \
                          --severity HIGH,CRITICAL \
                          --ignore-unfixed \
                          --format json \
                          -o trivy-fs.json \
                          package-lock.json || true

                        trivy convert --format table trivy-fs.json > trivy-fs.txt || true

                        # 2) npm audit as the fail gate (production dependencies only)
                        # This avoids failing on stale/non-runtime findings.
                        npm audit --omit=dev --audit-level=high --json > npm-audit.json || NPM_AUDIT_EXIT=$?

                        if [ "${NPM_AUDIT_EXIT:-0}" -ne 0 ]; then
                            echo "Production dependency vulnerabilities found (npm audit)."
                            exit 1
                        fi
                    '''

                }

                archiveArtifacts artifacts: 'frontend/trivy-fs.json,frontend/trivy-fs.txt,frontend/npm-audit.json', allowEmptyArchive: true

            }

        }

        stage('ESLint') {

            when {
                expression { buildRequired }
            }

            steps {

                dir('frontend') {

                    sh '''
                        echo "Running ESLint..."

                        npm run lint
                    '''

                }

            }

        }

        stage('Unit Test') {

            when {
                expression { buildRequired }
            }

            steps {

                dir('frontend') {

                    sh '''
                        echo "Running Unit Tests..."

                        npm test -- --ci --passWithNoTests --testPathIgnorePatterns=integration --coverage
                    '''

                }

            }

        }

        stage('Build') {

            when {
                expression { buildRequired }
            }

            steps {

                dir('frontend') {

                    sh '''
                        echo "Building Frontend Application..."

                        npm run build
                    '''

                }

            }

        }

        stage('SonarQube Scan') {

            when {
                expression { buildRequired }
            }

            steps {

                dir('frontend') {

                    withSonarQubeEnv('Sonar') {

                        sh '''
                            echo "Running SonarQube Analysis..."

                            ${SONAR_HOME}/bin/sonar-scanner \
                                -Dsonar.projectKey=wanderlust-frontend \
                                -Dsonar.projectName=wanderlust-frontend \
                                -Dsonar.sources=src \
                                -Dsonar.exclusions=**/node_modules/**,**/dist/**,**/__tests__/**,**/config/jest/** \
                                -Dsonar.tests=src/__tests__ \
                                -Dsonar.test.inclusions=**/*.test.tsx,**/*.test.ts \
                                -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info
                        '''

                    }

                }

            }

        }

        stage('Quality Gate') {

            when {
                expression { buildRequired }
            }

            steps {

                echo "Waiting for SonarQube Quality Gate..."

                timeout(time: 5, unit: 'MINUTES') {

                    waitForQualityGate abortPipeline: true

                }

            }

        }

        stage('Dockerfile Lint') {

            when {
                expression { buildRequired }
            }

            steps {

                dir('frontend') {

                    sh '''
                        echo "Scanning Dockerfile for misconfigurations..."

                        trivy config --severity HIGH,CRITICAL --exit-code 1 Dockerfile
                    '''

                }

            }

        }

        stage('Docker Build') {

            when {
                expression { buildRequired }
            }

            steps {

                dir('frontend') {

                    sh '''
                        echo "Building Docker image..."

                        IMAGE_TAG=${ACR_REGISTRY}/${APP_NAME}:${BUILD_NUMBER}
                        IMAGE_LATEST=${ACR_REGISTRY}/${APP_NAME}:latest

                        docker build -t ${IMAGE_TAG} -t ${IMAGE_LATEST} .
                    '''

                }

            }

        }

        stage('Docker Image Scan') {

            when {
                expression { buildRequired }
            }

            steps {

                sh '''
                    echo "Scanning Docker image for vulnerabilities..."

                    IMAGE_TAG=${ACR_REGISTRY}/${APP_NAME}:${BUILD_NUMBER}
                    trivy image --severity HIGH,CRITICAL --exit-code 1 ${IMAGE_TAG}
                '''

            }

        }

        stage('Push Image to ACR') {

            when {
                expression { buildRequired }
            }

            steps {

                withCredentials([
                    usernamePassword(
                        credentialsId: 'acr-credentials',
                        usernameVariable: 'ACR_USERNAME',
                        passwordVariable: 'ACR_PASSWORD'
                    )
                ]) {

                    sh '''
                        echo "Logging in to Azure Container Registry..."

                        echo ${ACR_PASSWORD} | docker login ${ACR_REGISTRY} -u ${ACR_USERNAME} --password-stdin

                        IMAGE_TAG=${ACR_REGISTRY}/${APP_NAME}:${BUILD_NUMBER}
                        IMAGE_LATEST=${ACR_REGISTRY}/${APP_NAME}:latest

                        echo "Pushing images to ACR..."
                        docker push ${IMAGE_TAG}
                        docker push ${IMAGE_LATEST}

                        docker logout ${ACR_REGISTRY}
                    '''

                }

            }

        }

    }

    post {

        success {

            echo "Frontend CI completed successfully."

        }

        failure {

            echo "Frontend CI failed."

        }

        always {

            cleanWs()

        }

    }

}
