def buildRequired = false

pipeline {

    agent {
        label 'ubuntu'
    }

    options {
        timestamps()
        ansiColor('xterm')
        disableConcurrentBuilds()
        skipDefaultCheckout(true)

        buildDiscarder(logRotator(
            numToKeepStr: '20',
            artifactNumToKeepStr: '10'
        ))
    }

    environment {
        APP_NAME = "wanderlust-frontend"
        SONAR_HOME = tool 'Sonar'
    }

    stages {

        stage('Checkout') {
            steps {

                echo "Checking out source code..."

                checkout scm

                sh '''
                    echo "Current Workspace"
                    pwd

                    echo "Repository Contents"
                    ls -la

                    echo "Frontend Directory"
                    ls -la frontend
                '''
            }
        }

        stage('Verify Build Agent') {
            steps {

                sh '''
                    echo "========= Installed Tools ========="

                    git --version
                    node --version
                    npm --version
                    docker --version
                    kubectl version --client
                    helm version
                    az version
                    java -version
                    trivy --version
                    sonar-scanner --version
                '''
            }
        }

        stage('Detect Frontend Changes') {

            steps {

                script {

                    /*
                     * Compare previous successful build with current commit.
                     * First build fallback -> HEAD~1
                     */

                    def previousCommit = env.GIT_PREVIOUS_SUCCESSFUL_COMMIT

                    def currentCommit = env.GIT_COMMIT

                    def diffCommand

                    if (previousCommit?.trim()) {
                        diffCommand = "git diff --name-only ${previousCommit} ${currentCommit}"
                    } else {
                        diffCommand = "git diff --name-only HEAD~1 HEAD || true"
                    }

                    def changedFiles = sh(
                        script: diffCommand,
                        returnStdout: true
                    ).trim().split('\n')

                    echo "========== Changed Files =========="

                    changedFiles.each {
                        echo it
                    }

                    def triggerPatterns = [

                        ~/^frontend\/src\/.*/,
                        ~/^frontend\/public\/.*/,
                        ~/^frontend\/package\.json$/,
                        ~/^frontend\/package-lock\.json$/,
                        ~/^frontend\/vite\.config\.ts$/,
                        ~/^frontend\/tsconfig.*$/,
                        ~/^frontend\/tailwind\.config\.js$/,
                        ~/^frontend\/postcss\.config\.js$/,
                        ~/^frontend\/components\.json$/,
                        ~/^frontend\/index\.html$/,
                        ~/^frontend\/Dockerfile$/,
                        ~/^frontend\/\.env.*/
                    ]

                    for (file in changedFiles) {

                        if (triggerPatterns.any { file ==~ it }) {

                            buildRequired = true
                            break

                        }

                    }

                    if (!buildRequired) {

                        echo "No frontend application changes detected. Skipping pipeline."
                        currentBuild.result = 'NOT_BUILT'
                        currentBuild.description = 'Skipped - no frontend code changes'

                    } else {

                        echo "Frontend changes detected."

                    }

                }

            }

        }

        stage('Install Dependencies') {

            when {
                expression { buildRequired }
            }

            steps {

                dir('frontend') {

                    sh '''
                        echo "Installing Node Packages..."
                        npm ci
                    '''

                }

            }

        }

        stage('Dependency Scan') {

            when {
                expression { buildRequired }
            }

            steps {

                dir('frontend') {

                    sh '''
                        echo "Scanning dependencies for vulnerabilities..."

                        trivy fs --scanners vuln --severity HIGH,CRITICAL --exit-code 1 package-lock.json
                    '''

                }

            }

        }

        stage('ESLint') {

            when {
                expression { buildRequired }
            }

            steps {

                dir('frontend') {

                    sh '''
                        echo "Running ESLint..."

                        npm run lint
                    '''

                }

            }

        }

        stage('Unit Test') {

            when {
                expression { buildRequired }
            }

            steps {

                dir('frontend') {

                    sh '''
                        echo "Running Unit Tests..."

                        npm test -- --ci --passWithNoTests
                    '''

                }

            }

        }

        stage('Build') {

            when {
                expression { buildRequired }
            }

            steps {

                dir('frontend') {

                    sh '''
                        echo "Building Frontend Application..."

                        npm run build
                    '''

                }

            }

        }

        stage('Dockerfile Lint') {

            when {
                expression { buildRequired }
            }

            steps {

                dir('frontend') {

                    sh '''
                        echo "Scanning Dockerfile for misconfigurations..."

                        trivy config --severity HIGH,CRITICAL --exit-code 1 Dockerfile
                    '''

                }

            }

        }

        stage('SonarQube Scan') {

            when {
                expression { buildRequired }
            }

            steps {

                dir('frontend') {

                    withSonarQubeEnv('Sonar') {

                        sh '''
                            echo "Running SonarQube Analysis..."

                            ${SONAR_HOME}/bin/sonar-scanner \
                                -Dsonar.projectKey=wanderlust-frontend \
                                -Dsonar.projectName=wanderlust-frontend \
                                -Dsonar.sources=src \
                                -Dsonar.exclusions=**/node_modules/**,**/dist/**,**/__tests__/**,**/config/jest/** \
                                -Dsonar.tests=src/__tests__ \
                                -Dsonar.test.inclusions=**/*.test.tsx,**/*.test.ts \
                                -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info
                        '''

                    }

                }

            }

        }

        stage('Quality Gate') {

            when {
                expression { buildRequired }
            }

            steps {

                echo "Waiting for SonarQube Quality Gate..."

                timeout(time: 5, unit: 'MINUTES') {

                    waitForQualityGate abortPipeline: true

                }

            }

        }

    }

    post {

        success {

            echo "Frontend CI completed successfully."

        }

        failure {

            echo "Frontend CI failed."

        }

        always {

            cleanWs()

        }

    }

}
